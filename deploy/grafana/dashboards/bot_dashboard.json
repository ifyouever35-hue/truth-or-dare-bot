{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Truth or Dare Bot — HTTP метрики, запросы, ошибки",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "📈 Запросов в секунду (RPS)",
      "description": "Количество HTTP запросов в секунду ко всему приложению. Spike = много пользователей.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "RPS total",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"2..\"}[1m]))",
          "legendFormat": "RPS 2xx (успех)",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"[45]..\"}[1m]))",
          "legendFormat": "RPS ошибки (4xx/5xx)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 2,
      "title": "⏱ Время ответа (p50 / p95 / p99)",
      "description": "Латентность. p95 > 500ms = проблема. p99 > 2s = критично.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50 (медиана)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },

    {
      "id": 3,
      "title": "❌ Процент ошибок",
      "description": "Доля 4xx/5xx ответов. Норма < 1%. Выше 5% = тревога.",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"[45]..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
          "legendFormat": "Error rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true }
    },

    {
      "id": 4,
      "title": "🔗 Активные HTTP соединения",
      "description": "Число одновременных соединений к uvicorn.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(http_requests_in_progress)",
          "legendFormat": "In progress",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto" }
    },

    {
      "id": 5,
      "title": "📊 Запросы по эндпоинтам",
      "description": "/webhook — основной (Telegram апдейты). /admin — панель. Аномальный рост одного = возможная атака.",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, sum(rate(http_requests_total[5m])) by (handler))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },

    {
      "id": 6,
      "title": "💾 Память процесса (RSS)",
      "description": "Потребление RAM ботом. Рост без плато = memory leak.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS Memory",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      }
    },

    {
      "id": 7,
      "title": "🐍 Время CPU (user + system)",
      "description": "Суммарное процессорное время. Ровный рост = нормально. Экспоненциальный = проблема в коде.",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[1m])",
          "legendFormat": "CPU usage",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["telegram", "bot", "python"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Truth or Dare Bot",
  "uid": "tod-bot-dashboard",
  "version": 1
}
