# =============================================================================
# .env.example — скопируй в .env и заполни значения.
#   cp .env.example .env
#   nano .env
# =============================================================================

# ── ОБЯЗАТЕЛЬНО ─────────────────────────────────────────────────────────────
# Токен Telegram-бота от @BotFather (/newbot)
BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE

# Пароли БД и админ-панели — придумай сложные
POSTGRES_PASSWORD=change_me_strong_password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password

# Любая случайная строка (>=32 символа). Сгенерировать:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET_KEY=change_me_random_long_string

# ── Webhook (опционально) ────────────────────────────────────────────────────
# Если указан — бот работает через webhook (нужен HTTPS-домен и nginx).
# Если ПУСТО — бот сам перейдёт в polling. Удобно для VM без домена.
WEBHOOK_HOST=
WEBHOOK_PATH=/webhook
# Секретный токен, которым Telegram подписывает запросы. Любая случайная строка.
WEBHOOK_SECRET=change_me_webhook_secret

# ── Сервисы (НЕ менять при запуске через docker compose) ────────────────────
# Эти значения перезаписываются в docker-compose.yml для контейнера app.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=truth_or_dare
POSTGRES_USER=tod_user

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── Платежи (опционально) ────────────────────────────────────────────────────
STARS_PROVIDER_TOKEN=

# ── Игровые настройки ───────────────────────────────────────────────────────
TASK_TIMER_SECONDS=120
DEFAULT_LIVES=3
MAX_LOBBY_SIZE=10
MAX_ROUNDS=10

BUYOUT_COST_STARS=5

VERIFIED_STARS_PRICE=99
VERIFIED_RENEWAL_DISCOUNT=20
VERIFIED_DURATION_DAYS=30
VERIFIED_PRICE_UAH=49

STARS_PACK_SMALL_PRICE=50
STARS_PACK_MEDIUM_PRICE=150
STARS_PACK_LARGE_PRICE=350
STARS_PACK_SMALL_BONUS=50
STARS_PACK_MEDIUM_BONUS=170
STARS_PACK_LARGE_BONUS=420

# ── Медиа ────────────────────────────────────────────────────────────────────
MEDIA_DIR=/app/media_storage
MAX_PHOTO_SIZE_MB=10
MAX_VIDEO_SIZE_MB=50
MEDIA_RETENTION_DAYS=7
