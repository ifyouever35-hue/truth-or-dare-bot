MAX_LOBBY_SIZE=10
MAX_ROUNDS=10
BUYOUT_COST_STARS=5
VERIFIED_STARS_PRICE=99
VERIFIED_RENEWAL_DISCOUNT=20
VERIFIED_DURATION_DAYS=30
VERIFIED_PRICE_UAH=49
STARS_PACK_SMALL_PRICE=50
STARS_PACK_MEDIUM_PRICE=150
STARS_PACK_LARGE_PRICE=350
STARS_PACK_SMALL_BONUS=50
STARS_PACK_MEDIUM_BONUS=170
STARS_PACK_LARGE_BONUS=420

ADMIN_SECRET_KEY=смени_на_случайную_строку
MEDIA_DIR=./media_storage
MAX_PHOTO_SIZE_MB=10
MAX_VIDEO_SIZE_MB=50
