# ── Обязательно заполнить ─────────────────────────────────────────────────────
BOT_TOKEN=вставь_токен_от_botfather

POSTGRES_DB=truth_or_dare
POSTGRES_USER=tod_user
POSTGRES_PASSWORD=придумай_сложный_пароль

ADMIN_USERNAME=admin
ADMIN_PASSWORD=придумай_пароль

# ── Не менять при деплое на VM ────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
