# ── Виртуальные окружения ────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Python мусор ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Git ──────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Локальные секреты и логи ─────────────────────────────────────────────────
.env
.env.local
*.log
bot.log
logs/*
!logs/.gitkeep

# ── Локальные данные, которые не нужны в образе ──────────────────────────────
media_storage/*
!media_storage/.gitkeep
backups/*
!backups/.gitkeep

# ── Docker файлы (сам Dockerfile не нужен внутри контейнера) ─────────────────
Dockerfile
docker-compose*.yml
.dockerignore

# ── Документация ─────────────────────────────────────────────────────────────
README.md
PATCH_NOTES.md

# ── Локальные скрипты запуска (не нужны в продакшн-образе) ───────────────────
start.sh
start.bat
stop.sh
stop.bat
run_local.py
bot.py

# ── Тесты — в продакшн-образе не нужны ───────────────────────────────────────
tests/
