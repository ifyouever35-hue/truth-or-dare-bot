# ════════════════════════════════════════════════════════════
#  .env.local — конфиг для запуска НА СВОЁМ КОМПЬЮТЕРЕ
#
#  КАК ИСПОЛЬЗОВАТЬ:
#    1. Скопировать в .env:   copy .env.local .env  (Windows)
#    2. Вставить BOT_TOKEN от @BotFather
#    3. Запустить:  python bot.py
# ════════════════════════════════════════════════════════════

# ╔══════════════════════════════════╗
# ║  ВСТАВИТЬ ТОКЕН ОТ @BotFather   ║
# ╚══════════════════════════════════╝
BOT_TOKEN=CHANGE_ME

# ── База данных ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=truth_or_dare
POSTGRES_USER=tod_user
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME

# ── Webhook (оставить пустым — бот работает в режиме polling)
WEBHOOK_HOST=CHANGE_ME
WEBHOOK_PATH=CHANGE_ME
WEBHOOK_SECRET=CHANGE_ME

# ── Медиафайлы ─────────────────────────────────────────────
MEDIA_DIR=CHANGE_ME
MAX_PHOTO_SIZE_MB=CHANGE_ME
MAX_VIDEO_SIZE_MB=CHANGE_ME
MEDIA_RETENTION_DAYS=CHANGE_ME

# ── Админ панель ───────────────────────────────────────────
ADMIN_SECRET_KEY=CHANGE_ME
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

# ── Платежи (можно оставить пустым для локального теста) ───
STARS_PROVIDER_TOKEN=CHANGE_ME
WAYFORPAY_MERCHANT_ACCOUNT=CHANGE_ME
WAYFORPAY_SECRET_KEY=CHANGE_ME
WAYFORPAY_MERCHANT_DOMAIN=CHANGE_ME

# ── Игровые настройки ──────────────────────────────────────
TASK_TIMER_SECONDS=120
DEFAULT_LIVES=3
MAX_LOBBY_SIZE=10
BUYOUT_COST_STARS=5

# ── Stars магазин ──────────────────────────────────────────
STARS_PACK_SMALL_PRICE=50
STARS_PACK_MEDIUM_PRICE=150
STARS_PACK_LARGE_PRICE=350
STARS_PACK_SMALL_BONUS=50
STARS_PACK_MEDIUM_BONUS=170
STARS_PACK_LARGE_BONUS=420

# ── Verified 18+ ───────────────────────────────────────────
VERIFIED_STARS_PRICE=99
VERIFIED_PRICE_UAH=49
VERIFIED_DURATION_DAYS=30
VERIFIED_RENEWAL_DISCOUNT=20

# ── Grafana (только для продакшна) ─────────────────────────
GRAFANA_PASSWORD=CHANGE_ME

MAX_ROUNDS=10
